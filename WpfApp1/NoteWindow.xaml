<Window x:Class="QuickSticky.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Note"
        Width="460"
        Height="280"
        MinWidth="260"
        MinHeight="160"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="true"
        Background="#01000000"
        ShowInTaskbar="False"
        LocationChanged="Window_LocationOrSizeChanged"
        SizeChanged="Window_LocationOrSizeChanged"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="#EE181818" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="#EFFFFFFF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Root"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2AFFFFFF" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Margin="8,5"
                                Background="#24FFFFFF" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#D8FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#10FFFFFF" />
            <Setter Property="BorderBrush" Value="#35FFFFFF" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#35FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Margin="0"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#30FFFFFF"
            Background="#16000000"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect BlurRadius="34"
                              ShadowDepth="0"
                              Opacity="0.45" />
        </Border.Effect>

        <Grid ClipToBounds="True">

            <Border CornerRadius="10"
                    Background="#26000000" />

            <Border Height="68"
                    VerticalAlignment="Top"
                    CornerRadius="10,10,0,0"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#20FFFFFF" Offset="0" />
                        <GradientStop Color="#08FFFFFF" Offset="0.38" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border Margin="1"
                    CornerRadius="9"
                    BorderThickness="1"
                    BorderBrush="#12FFFFFF"
                    IsHitTestVisible="False" />

            <Grid Margin="10,4,8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Margin="0,0,8,0">

                        <!-- <Grid.ContextMenu> -->
                        <!--     <ContextMenu> -->
                        <!--         <MenuItem Header="Settings..." Click="SettingsMenuItem_Click" /> -->
                        <!--     </ContextMenu> -->
                        <!-- </Grid.ContextMenu> -->

                        <TextBlock x:Name="TitlePlaceholder"
                                   Text="Quick Note"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="#70FFFFFF"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />

                        <TextBox x:Name="TitleEditor"
                                 TextChanged="TitleEditor_TextChanged"
                                 PreviewMouseLeftButtonDown="TitleEditor_MouseLeftButtonDown"
                                 LostFocus="TitleEditor_LostFocus"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#F2FFFFFF"
                                 CaretBrush="White"
                                 SelectionBrush="#55FFFFFF"
                                 FontWeight="SemiBold"
                                 FontSize="13"
                                 FontFamily="Segoe UI"
                                 Padding="0"
                                 VerticalContentAlignment="Center" />
                    </Grid>

                    <Border Grid.Column="1"
                            Background="Transparent"
                            MouseLeftButtonDown="Window_MouseLeftButtonDown">

                        <!-- <Border.ContextMenu> -->
                        <!--     <ContextMenu> -->
                        <!--         <MenuItem Header="Settings..." Click="SettingsMenuItem_Click" /> -->
                        <!--     </ContextMenu> -->
                        <!-- </Border.ContextMenu> -->

                    </Border>

                    <Button Grid.Column="2"
                            Content="✕"
                            Style="{StaticResource GlassCloseButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="Close_Click" />
                </Grid>

                <TextBox x:Name="Editor"
                         Grid.Row="1"
                         Margin="0,2,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#F2FFFFFF"
                         CaretBrush="White"
                         SelectionBrush="#55FFFFFF"
                         FontFamily="Consolas"
                         FontSize="14"
                         Padding="0,2,4,4"
                         TextChanged="Editor_TextChanged">

                    <!-- <TextBox.ContextMenu> -->
                    <!--     <ContextMenu> -->
                    <!--         <MenuItem Header="Cut" Command="ApplicationCommands.Cut" /> -->
                    <!--         <MenuItem Header="Copy" Command="ApplicationCommands.Copy" /> -->
                    <!--         <MenuItem Header="Paste" Command="ApplicationCommands.Paste" /> -->
                    <!--         <Separator /> -->
                    <!--         <MenuItem Header="Settings..." Click="SettingsMenuItem_Click" /> -->
                    <!--     </ContextMenu> -->
                    <!-- </TextBox.ContextMenu> -->

                </TextBox>
            </Grid>
        </Grid>
    </Border>
</Window>